{{shard "Chart"}}

{{begin "Main"}}
{{set "apiVersion" "v2"}}
{{receive "name"}}
{{receive "description"}}
{{set "type" "application"}}
{{set "version" "0.1.0"}}
{{set "appVersion" "1.0"}}
{{set "dependencies" (list (map "name" "rikami" "version" "0.1.1" "repository" "oci://ghcr.io/b-zago/rikami-charts"))}}
{{seal}}
