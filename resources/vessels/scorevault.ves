{{conf "Chart"}}
---
{{cast "Chart" "Chart"}}
{{cast "WebServer" "web"}}
{{cast "PostgresDeploy" "db"}}
{{cast "Redis" "redis"}}
---
{{append .Chart.Main "dependencies[0]" (map "version" "0.1.13")}}
{{- global "env" "prod" -}}

{{override .Chart.Main "description" "App description"}}
{{request .Chart.Main "name" "Chart name"}}
{{$prefix := print .Chart.Main.name "-"}}

{{target .Chart.Main.name}}
		
{{override .web.Deployments "image" "ghcr.io/b-zago/scorevault/webserver:latest"}}
{{override .web.Deployments "runsOn" "python"}}
{{override .web.Deployments "envVars" (envGen "DB_HOST" (print $prefix .db.Services.name) "REDIS" (print $prefix .redis.Services.name))}}
{{override .web.Routes "host" "scorevault.zagoapps.com"}}
{{override .web.Services "targetPort" 8000}}
{{override .db.Deployments "image" "postgres:18-alpine"}}
{{override .db.Secrets "data" (secRand (print $prefix .db.Secrets.name) "POSTGRES_DB" "POSTGRES_PASSWORD" "POSTGRES_USER")}}
{{override .web.Deployments "envSecretRefs" (list .db.Secrets.name)}}
{{append .db.Secrets "runsOnList" (list .web.Deployments.name)}}
{{summon (print "values-" .Globals.Values.env)}}
{{global "env" "staging"}}
{{override .web.Routes "host" "scorevault-staging.zagoapps.com"}}
{{override .db.Secrets "data" (secRand (print $prefix .db.Secrets.name) "POSTGRES_DB" "POSTGRES_PASSWORD" "POSTGRES_USER")}}
{{summon (print "values-" .Globals.Values.env)}}
